# Server Configuration
PORT=10000
NODE_ENV=development

# PostgreSQL configuration for Render.com
# Use DATABASE_URL for Render.com deployments
DATABASE_URL=postgresql://user:password@localhost:5432/smartbin_database

# Alternative: Individual database variables (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=smartbin_database

# JWT / auth (adjust values for production)
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# CORS configuration (optional)
CLIENT_ORIGIN=http://localhost:3000

# For Render.com Production:
# 1. Set DATABASE_URL to your Render PostgreSQL connection string from the dashboard
# 2. Set PORT to desired port (default: 10000)
# 3. Set NODE_ENV=production